<?xml version="1.0" encoding="utf-8"?>
<!--
  计算器伪装图标前景：白色数学符号 2x2 网格（÷ × − +）
  蓝紫渐变背景配套使用
  设计规格：108dp 画布，安全区域 66dp（居中）
  网格中心：左列 x=40，右列 x=68，上行 y=42，下行 y=66
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">

  <!-- ÷ 除号 center(40,42) -->
  <path android:fillColor="#FFFFFF"
    android:pathData="M40,32.8a2.2,2.2 0 1,1 0,4.4a2.2,2.2 0 1,1 0,-4.4z"/>
  <path android:fillColor="#FFFFFF"
    android:pathData="M33.5,40.7h13a1.3,1.3 0 0 1 0,2.6h-13a1.3,1.3 0 0 1 0,-2.6z"/>
  <path android:fillColor="#FFFFFF"
    android:pathData="M40,46.8a2.2,2.2 0 1,1 0,4.4a2.2,2.2 0 1,1 0,-4.4z"/>

  <!-- × 乘号 center(68,42)，用旋转矩形确保完美对称 -->
  <group android:pivotX="68" android:pivotY="42" android:rotation="45">
    <path android:fillColor="#FFFFFF"
      android:pathData="M61.5,40.7h13a1.3,1.3 0 0 1 0,2.6h-13a1.3,1.3 0 0 1 0,-2.6z"/>
  </group>
  <group android:pivotX="68" android:pivotY="42" android:rotation="-45">
    <path android:fillColor="#FFFFFF"
      android:pathData="M61.5,40.7h13a1.3,1.3 0 0 1 0,2.6h-13a1.3,1.3 0 0 1 0,-2.6z"/>
  </group>

  <!-- − 减号 center(40,66) -->
  <path android:fillColor="#FFFFFF"
    android:pathData="M33.5,64.7h13a1.3,1.3 0 0 1 0,2.6h-13a1.3,1.3 0 0 1 0,-2.6z"/>

  <!-- + 加号 center(68,66) -->
  <path android:fillColor="#FFFFFF"
    android:pathData="M61.5,64.7h13a1.3,1.3 0 0 1 0,2.6h-13a1.3,1.3 0 0 1 0,-2.6z"/>
  <path android:fillColor="#FFFFFF"
    android:pathData="M69.3,59.5v13a1.3,1.3 0 0 1 -2.6,0v-13a1.3,1.3 0 0 1 2.6,0z"/>

